{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.js"
  ]
}
