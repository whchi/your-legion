{
  "name": "@whchi/your-legion",
  "version": "0.0.7",
  "description": "Plugin-first OpenCode multi-agent system inspired by oh-my-openagent",
  "homepage": "https://github.com/whchi/your-legion#readme",
  "bugs": {
    "url": "https://github.com/whchi/your-legion/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whchi/your-legion.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": "./dist/server.js",
    "./server": "./dist/server.js"
  },
  "main": "dist/server.js",
  "bin": {
    "your-legion": "./dist/cli.js"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "INSTALLATION.md",
    "DEVELOPMENT.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --target node --format esm --outfile dist/server.js && bun build src/cli.ts --target node --format esm --outfile dist/cli.js && cp legionaries.yaml dist/legionaries.yaml",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "yaml": "^2.8.4"
  },
  "devDependencies": {},
  "engines": {
    "opencode": ">=0.1.0",
    "bun": ">=1.1.0"
  }
}
